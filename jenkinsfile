pipeline {
    agent any

    tools {
        // These names must match your 'Global Tool Configuration'
        dotnetsdk 'dontnet-8' 
        git 'Git'
    }

    stages {
        stage('Checkout') {
            steps {
                // Pulls the code from the GitHub repo that triggered the job
                checkout scm
            }
        }

        stage('Build & SonarQube Analysis') {
            steps {
                // 1. Link the Jenkins Credential ID to the variable SONAR_TOKEN
                withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                    
                    // 2. Inject the SonarQube Server URL and system settings
                    withSonarQubeEnv('sonarQube server') {
                        sh """
                            # Ensure the scanner tool is installed globally on the agent
                            dotnet tool install --global dotnet-sonarscanner || true
                            
                            # Add the dotnet tools directory to the PATH for this session
                            export PATH="\$PATH:\$HOME/.dotnet/tools"

                            # Start the analysis (Project Key can be anything unique)
                            dotnet sonarscanner begin /k:"eShopOnWeb-Hybrid" /d:sonar.token=\${SONAR_TOKEN}

                            # Compile the solution
                            dotnet build eShopOnWeb.sln

                            # Finalize analysis and upload results to the SonarQube dashboard
                            dotnet sonarscanner end /d:sonar.token=\${SONAR_TOKEN}
                        """
                    }
                }
            }
        }
    }

    post {
        success {
            echo "✅ Build and Analysis completed successfully!"
        }
        failure {
            echo "❌ Pipeline failed. Check the console output for errors."
        }
    }
}
