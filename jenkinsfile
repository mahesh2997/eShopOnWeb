pipeline {
    agent any
    
    tools {
        dotnetsdk 'dontnet-8'
        git 'Git'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build & SonarQube Analysis') {
            steps {
                withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                    withSonarQubeEnv('sonarQube server') {
                        sh """
                            export PATH="\$PATH:\$HOME/.dotnet/tools"
                            export SONAR_SCANNER_OPTS="-Xmx512m -Xms128m"

                            dotnet sonarscanner begin /k:"eShopOnWeb-Hybrid" /d:sonar.token=\${SONAR_TOKEN}
                            dotnet build eShopOnWeb.sln -maxcpucount:1 /p:NodeReuse=false
                            dotnet sonarscanner end /d:sonar.token=\${SONAR_TOKEN}
                        """
                    }
                }
            }
        }

        stage('Deploy to Local Windows') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'windows-local-creds', passwordVariable: 'WIN_PASS', usernameVariable: 'WIN_USER')]) {
                    sh """
                        # Disable command echoing to protect the password in logs
                        set +x
                        # Show us exactly what the shell thinks the username is
                        echo "DEBUG: The username being sent is: ${WIN_USER}"
                        
                        set +x
                        # Create a very simple inventory without the problematic variables
                        echo "[windows]" > inventory.ini
                        echo "plaided-reliably-twanda.ngrok-free.dev ansible_port=443 ansible_connection=winrm ansible_winrm_server_cert_validation=ignore ansible_winrm_transport=basic" >> inventory.ini
                    
                        echo "Testing connection to local machine..."
                        # Pass BOTH the user and the password as extra vars to avoid INI parsing issues
                        ansible windows -i inventory.ini -m win_ping -e "ansible_user='${WIN_USER}' ansible_password=\$WIN_PASS"
                    """
                }
            }
        }
    }

    post {
        success {
            echo "✅ Build, Analysis, and Connection successful!"
        }
        failure {
            echo "❌ Pipeline failed. Check the console output."
        }
    }
}
