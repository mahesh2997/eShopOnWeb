pipeline {
    agent any

    tools {
        // These names must match your 'Global Tool Configuration'
        dotnetsdk 'dontnet-8' 
        git 'Git'
    }

    stages {
        stage('Checkout') {
            steps {
                // Pulls the code from the GitHub repo that triggered the job
                checkout scm
            }
        }

        stage('Build & SonarQube Analysis') {
            steps {
                // 1. Link the Jenkins Credential ID to the variable SONAR_TOKEN
                withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                    
                    // 2. Inject the SonarQube Server URL and system settings
                    withSonarQubeEnv('sonarQube server') {
                        sh """
                                # 1. Setup PATH
                                export PATH="\$PATH:\$HOME/.dotnet/tools"
                            
                                # 2. LIMIT MEMORY (The 'Leash' for Java)
                                export SONAR_SCANNER_OPTS="-Xmx512m -Xms128m"
                            
                                # 3. BEGIN SCAN
                                dotnet sonarscanner begin /k:"eShopOnWeb-Hybrid" /d:sonar.token=\${SONAR_TOKEN}
                            
                                # 4. LIMIT CPU (The 'Speed Limit' for .NET)
                                # -maxcpucount:1 ensures we only use 1 core so the server doesn't freeze
                                dotnet build eShopOnWeb.sln -maxcpucount:1 /p:NodeReuse=false
                            
                                # 5. END SCAN
                                dotnet sonarscanner end /d:sonar.token=\${SONAR_TOKEN}
                            """
                    }
                }
            }
        }
    }

    post {
        success {
            echo "✅ Build and Analysis completed successfully!"
        }
        failure {
            echo "❌ Pipeline failed. Check the console output for errors."
        }
    }
}

