pipeline {
    agent any
    
    tools {
        dotnetsdk 'dontnet-8'
        git 'Git'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build & SonarQube Analysis') {
            steps {
                withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                    withSonarQubeEnv('sonarQube server') {
                        sh """
                            export PATH="\$PATH:\$HOME/.dotnet/tools"
                            export SONAR_SCANNER_OPTS="-Xmx512m -Xms128m"

                            dotnet sonarscanner begin /k:"eShopOnWeb-Hybrid" /d:sonar.token=\${SONAR_TOKEN}
                            dotnet build eShopOnWeb.sln -maxcpucount:1 /p:NodeReuse=false
                            dotnet sonarscanner end /d:sonar.token=\${SONAR_TOKEN}
                        """
                    }
                }
            }
        }

        stage('Deploy to Local Windows') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'windows-local-creds', passwordVariable: 'WIN_PASS', usernameVariable: 'WIN_USER')]) {
                    sh """
                        # Create Inventory
                        echo "[windows]" > inventory.ini
                        echo "plaided-reliably-twanda.ngrok-free.dev ansible_port=443 ansible_user=\${WIN_USER} ansible_password=\${WIN_PASS} ansible_connection=winrm ansible_winrm_server_cert_validation=ignore" >> inventory.ini

                        # Test Connection
                        echo "Testing connection to local machine via ngrok..."
                        ansible windows -i inventory.ini -m win_ping
                    """
                }
            }
        }
    }

    post {
        success {
            echo "✅ Build, Analysis, and Connection successful!"
        }
        failure {
            echo "❌ Pipeline failed. Check the console output."
        }
    }
}
